# Gitignore for Bupzo Project

# Operating System Files
.next/
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# IDE and Editor Files
.idea/
.vscode/
*.iml
*.ipr
*.iws
.project
.classpath
.settings/
.c9/

# Build Artifacts
/target/
/build/
/dist/
*.jar
*.war
*.ear
*.class

# Dependency Directories
/node_modules/
/vendor/

# Log Files
*.log
log/

# Environment Variables and Configuration
.env
.env.*
config.local.json

# Temporary Files
*~
*.tmp
*.bak
*.swp

# Python Specific (if applicable)
__pycache__/
*.pyc

# Node.js Specific (if applicable)
npm-debug.log
yarn-error.log

# Database specific (if local files are generated, e.g., SQLite)
*.sqlite
*.db

# Other common ignored files
coverage/
*.json
*.pid
*.sock
*.sublime-project
*.sublime-workspace