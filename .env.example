# BUPZO API Configurations & Secrets

# Google Gemini API key for AI Product Studio & Dispute Resolution
GEMINI_API_KEY=your_gemini_api_key_here

# Meta Cloud WhatsApp API Token
WHATSAPP_API_TOKEN=your_whatsapp_api_token_here

# Brevo (Sendinblue) API Key for Email transactional updates
BREVO_API_KEY=your_brevo_api_key_here

# Supabase Configurations (Production DB)
SUPABASE_URL=your_supabase_url_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here
