# BUPZO V10 - Environment Variables Example

# Database Configuration
POSTGRES_USER=bupzo_user
POSTGRES_PASSWORD=bupzo_password
POSTGRES_DB=bupzo_db

# API Keys (Replace with actual keys in .env)
GEMINI_API_KEY=your_gemini_api_key_here
WHATSAPP_API_TOKEN=your_whatsapp_api_token_here
BREVO_API_KEY=your_brevo_api_key_here
SUPABASE_URL=your_supabase_url_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Redis Configuration
REDIS_URL=redis://localhost:6380

# Backend Configuration
DATABASE_URL=postgresql://bupzo_user:bupzo_password@localhost:5434/bupzo_db
BACKEND_PORT=8003

# Frontend Configuration
NEXT_PUBLIC_API_URL=http://localhost:8003
NEXT_PUBLIC_MCP_URL=http://localhost:3004
NEXT_PUBLIC_PORT=3003

# Admin Frontend Configuration
NEXT_PUBLIC_ADMIN_API_URL=http://localhost:8003
NEXT_PUBLIC_ADMIN_MCP_URL=http://localhost:3004
NEXT_PUBLIC_ADMIN_PORT=3005

# MCP Server Configuration
MCP_PORT=3004

# Firebase Configuration (for OTP and Auth)
FIREBASE_API_KEY=your_firebase_api_key_here
FIREBASE_AUTH_DOMAIN=your_firebase_auth_domain_here
FIREBASE_PROJECT_ID=your_firebase_project_id_here
FIREBASE_STORAGE_BUCKET=your_firebase_storage_bucket_here
FIREBASE_MESSAGING_SENDER_ID=your_firebase_messaging_sender_id_here
FIREBASE_APP_ID=your_firebase_app_id_here

# Payment Gateways
RAZORPAY_KEY_ID=your_razorpay_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here
CASHFREE_CLIENT_ID=your_cashfree_client_id_here
CASHFREE_CLIENT_SECRET=your_cashfree_client_secret_here

# Shipping Partners
SHIPROCKET_API_KEY=your_shiprocket_api_key_here
NIMBUSPOST_API_KEY=your_nimbuspost_api_key_here
DELHIVERY_API_KEY=your_delhivery_api_key_here

# Miscellaneous
JWT_SECRET=your_jwt_secret_here
SESSION_SECRET=your_session_secret_here