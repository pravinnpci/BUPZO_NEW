# ==============================================================================
# BUPZO ENVIRONMENT VARIABLES TEMPLATE
# ==============================================================================

# --- DATABASE (Local & Supabase) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=bupzo
DATABASE_URL=postgresql://postgres:postgres@localhost:5434/bupzo
SUPABASE_URL=your_supabase_url_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_here

# --- CACHING & RATE LIMITING (Local & Upstash) ---
REDIS_URL=redis://localhost:6380/0
UPSTASH_REDIS_REST_URL=your_upstash_url_here
UPSTASH_REDIS_REST_TOKEN=your_upstash_token_here

# --- AI ENGINE (Gemini & Mistral) ---
GEMINI_API_KEY=your_gemini_api_key_here
MISTRAL_API_KEY=your_mistral_api_key_here

# --- PAYMENT GATEWAYS ---
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
CASHFREE_APP_ID=your_cashfree_app_id
CASHFREE_SECRET_KEY=your_cashfree_secret_key
PHONEPE_MERCHANT_ID=your_phonepe_merchant_id
PHONEPE_SALT_KEY=your_phonepe_salt_key

# --- SHIPPING PARTNERS ---
SHIPROCKET_EMAIL=your_shiprocket_email
SHIPROCKET_PASSWORD=your_shiprocket_password
NIMBUSPOST_EMAIL=your_nimbuspost_email
NIMBUSPOST_PASSWORD=your_nimbuspost_password
DELHIVERY_API_TOKEN=your_delhivery_api_token

# --- COMMUNICATIONS & NOTIFICATIONS ---
META_WHATSAPP_API_TOKEN=your_meta_whatsapp_token
META_WHATSAPP_PHONE_NUMBER_ID=your_meta_phone_id
BREVO_API_KEY=your_brevo_api_key
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_MESSAGING_SENDER_ID=your_firebase_sender_id

# --- APP CONFIGURATION ---
FRONTEND_URL=http://localhost:3003
BACKEND_URL=http://localhost:8003
MCP_SERVER_URL=http://localhost:3004
ENVIRONMENT=development
JWT_SECRET=your_super_secret_jwt_key_change_me
