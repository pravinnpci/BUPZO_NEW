# Database Configuration
DB_HOST=db
DB_PORT=5432
DB_NAME=bupzo_db
DB_USER=bupzo_user
DB_PASSWORD=bupzo_password
DB_SSL_MODE=disable

# Caching Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# Supabase Configuration
SUPABASE_URL=
SUPABASE_KEY=

# AI Configuration
GEMINI_API_KEY=
GEMINI_MODEL=gemini-pro

# Payments Configuration
PAYMENT_GATEWAYS=
  - name: Razorpay
    enabled: true
    api_key: ${RAZORPAY_API_KEY}
    api_secret: ${RAZORPAY_API_SECRET}
  - name: Cashfree
    enabled: false
    api_key: ${CASHFREE_API_KEY}
    api_secret: ${CASHFREE_API_SECRET}
  - name: PhonePe
    enabled: false
    api_key: ${PHONEPE_API_KEY}
    api_secret: ${PHONEPE_API_SECRET}

# Shipping Configuration
SHIPPING_PARTNERS=
  - name: Shiprocket
    enabled: true
    api_key: ${SHIPROCKET_API_KEY}
    api_secret: ${SHIPROCKET_API_SECRET}
  - name: NimbusPost
    enabled: false
    api_key: ${NIMBUSPOST_API_KEY}
    api_secret: ${NIMBUSPOST_API_SECRET}
  - name: Delhivery
    enabled: false
    api_key: ${DELHERRY_API_KEY}
    api_secret: ${DELHERRY_API_SECRET}

# Communications Configuration
WHATSAPP_API_KEY=
WHATSAPP_API_SECRET=
WHATSAPP_BUSINESS_ACCOUNT_ID=

BREVO_API_KEY=
BREVO_SENDER_EMAIL=

FIREBASE_API_KEY=
FIREBASE_PROJECT_ID=
FIREBASE_AUTH_DOMAIN=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=

# Application Configuration
NEXT_PUBLIC_API_URL=http://localhost:8003/api
NEXT_PUBLIC_REDIS_URL=redis://localhost:6379
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_KEY=

# Development Configuration
NODE_ENV=development
PORT=8000