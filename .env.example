# ==========================================
# BUPZO SYSTEM ENVIRONMENT VARIABLES
# ==========================================

# 1. Database (PostgreSQL via Supabase or Local Docker)
# Note: Docker uses the internal network resolving "db" at 5432.
DATABASE_URL=postgresql://bupzo_user:bupzo_password@db:5432/bupzo_db
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# 2. Caching & Rate Limiting (Redis via Upstash or Local Docker)
# Note: Docker uses the internal network resolving "redis" at 6379.
REDIS_URL=redis://redis:6379/0
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# 3. AI Engine (Google Gemini)
GEMINI_API_KEY=

# 4. Payments (Multi-Aggregator Routing)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
CASHFREE_APP_ID=
CASHFREE_SECRET_KEY=
PHONEPE_MERCHANT_ID=
PHONEPE_SALT_KEY=

# 5. Shipping (Multi-Aggregator Routing)
SHIPROCKET_EMAIL=
SHIPROCKET_PASSWORD=
SHIPROCKET_TOKEN=
NIMBUSPOST_API_KEY=
DELHIVERY_API_TOKEN=

# 6. Communications & Auth (WhatsApp, Firebase, Brevo)
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_SERVER_KEY=
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
BREVO_API_KEY=